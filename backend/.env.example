# App
DEBUG=true

# Database (overridden in docker-compose)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/babycam

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Secret (CHANGE IN PRODUCTION)
SECRET_KEY=dev-secret-key-change-me

# LLM Provider: "gemini", "openai", or "openai_compatible"
LLM_PROVIDER=gemini

# Gemini API
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# OpenAI API (fallback)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# OpenAI-Compatible API (Stepfun, Kimi, DeepSeek, Qwen, etc.)
# Set LLM_PROVIDER=openai_compatible to use these:
COMPATIBLE_API_KEY=your-api-key
COMPATIBLE_API_BASE=https://api.stepfun.com/v1
COMPATIBLE_MODEL=step-1v-8k
# Examples:
#   Stepfun:  COMPATIBLE_API_BASE=https://api.stepfun.com/v1  COMPATIBLE_MODEL=step-1v-8k
#   Kimi:     COMPATIBLE_API_BASE=https://api.moonshot.cn/v1  COMPATIBLE_MODEL=moonshot-v1-8k-vision
#   DeepSeek: COMPATIBLE_API_BASE=https://api.deepseek.com/v1 COMPATIBLE_MODEL=deepseek-chat

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=babycam-clips

# Stream Pipeline
FRAME_SAMPLE_INTERVAL=3.0
BUFFER_DURATION=45
CLIP_DURATION_BEFORE=15
CLIP_DURATION_AFTER=15

# Detection Thresholds
SINGLE_FRAME_CONFIDENCE=0.70
CONFIRMED_CONFIDENCE=0.80
COOLDOWN_MINUTES=5
